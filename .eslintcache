            </MenuItem>\r\n                {\r\n                Object.keys(state).map((item) => {\r\n                  if(item !== 'checkedAll')return <MenuItem id={item} key={i} onClick={update}><Checkbox id={item} name={item} checked={state[item]} inputProps={{ 'arialabel': 'primary checkbox' }}></Checkbox>{names[i++]}</MenuItem>\r\n                })}\r\n            </Menu>\r\n            );\r\n}\r\n\r\nMenuInterventions.propTypes = {};\r\n\r\nMenuInterventions.defaultProps = {};\r\n\r\nexport default MenuInterventions;\r\n",{"ruleId":"42","replacedBy":"43"},{"ruleId":"44","replacedBy":"45"},{"ruleId":"46","severity":1,"message":"47","line":289,"column":46,"nodeType":"48","messageId":"49","endLine":289,"endColumn":48},{"ruleId":"50","severity":1,"message":"51","line":291,"column":88,"nodeType":"52","messageId":"53","endLine":291,"endColumn":89,"suggestions":"54"},{"ruleId":"55","severity":1,"message":"56","line":5,"column":5,"nodeType":"57","messageId":"58","endLine":5,"endColumn":6},{"ruleId":"46","severity":1,"message":"47","line":29,"column":74,"nodeType":"48","messageId":"49","endLine":29,"endColumn":76},{"ruleId":"55","severity":1,"message":"59","line":3,"column":8,"nodeType":"57","messageId":"58","endLine":3,"endColumn":14},{"ruleId":"60","severity":1,"message":"61","line":25,"column":5,"nodeType":"62","endLine":25,"endColumn":7,"suggestions":"63"},{"ruleId":"60","severity":1,"message":"61","line":30,"column":5,"nodeType":"62","endLine":30,"endColumn":7,"suggestions":"64"},{"ruleId":"46","severity":1,"message":"47","line":50,"column":47,"nodeType":"48","messageId":"49","endLine":50,"endColumn":49},"no-native-reassign",["65"],"no-negated-in-lhs",["66"],"array-callback-return","Array.prototype.map() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","no-useless-escape","Unnecessary escape character: \\-.","Literal","unnecessaryEscape",["67","68"],"no-unused-vars","'i' is assigned a value but never used.","