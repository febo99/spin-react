                 </MenuItem>\r\n                {\r\n                Object.keys(state).map((item) => {\r\n                  if(item !== 'checkedAll')return <MenuItem id={item} key={i} onClick={update}><Checkbox id={item} name={item} checked={state[item]} inputProps={{ 'arialabel': 'primary checkbox' }}></Checkbox>{names[i++]}</MenuItem>\r\n                })}\r\n            </Menu>\r\n            );\r\n}\r\n\r\nMenuInterventions.propTypes = {};\r\n\r\nMenuInterventions.defaultProps = {};\r\n\r\nexport default MenuInterventions;\r\n",{"ruleId":"43","replacedBy":"44"},{"ruleId":"45","replacedBy":"46"},{"ruleId":"47","severity":1,"message":"48","line":4,"column":25,"nodeType":"49","messageId":"50","endLine":4,"endColumn":33},{"ruleId":"47","severity":1,"message":"51","line":4,"column":43,"nodeType":"49","messageId":"50","endLine":4,"endColumn":47},{"ruleId":"47","severity":1,"message":"52","line":3,"column":8,"nodeType":"49","messageId":"50","endLine":3,"endColumn":14},{"ruleId":"47","severity":1,"message":"53","line":5,"column":5,"nodeType":"49","messageId":"50","endLine":5,"endColumn":6},{"ruleId":"54","severity":1,"message":"55","line":28,"column":74,"nodeType":"56","messageId":"57","endLine":28,"endColumn":76},{"ruleId":"47","severity":1,"message":"52","line":3,"column":8,"nodeType":"49","messageId":"50","endLine":3,"endColumn":14},{"ruleId":"58","severity":1,"message":"59","line":25,"column":5,"nodeType":"60","endLine":25,"endColumn":7,"suggestions":"61"},{"ruleId":"58","severity":1,"message":"59","line":30,"column":5,"nodeType":"60","endLine":30,"endColumn":7,"suggestions":"62"},{"ruleId":"54","severity":1,"message":"55","line":50,"column":47,"nodeType":"56","messageId":"57","endLine":50,"endColumn":49},"no-native-reassign",["63"],"no-negated-in-lhs",["64"],"no-unused-vars","'MenuItem' is defined but never used.","Identifier","unusedVar","'Menu' is defined but never used.","'styles' is defined but never used.","'i' is assigned a value but never used.","array-cal